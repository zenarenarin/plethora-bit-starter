{
  "id": "plethora-bit",
  "schemaVersion": 1,
  "runtimeVersion": "plethora-bit@1",
  "entryDefault": "main.js",
  "runtimeGlobal": "plethoraBit",
  "legacyRuntimeGlobal": "scrollerApp",
  "networkAllowedHosts": [
    "ajax.googleapis.com",
    "code.playcanvas.com",
    "cdn.jsdelivr.net",
    "cdn.skypack.dev",
    "cdnjs.cloudflare.com",
    "esm.sh",
    "fonts.googleapis.com",
    "fonts.gstatic.com",
    "ga.jspm.io",
    "jspm.dev",
    "unpkg.com"
  ],
  "permissions": [
    "audio",
    "camera",
    "haptics",
    "microphone",
    "motion",
    "networkFetch",
    "storage"
  ],
  "patterns": {
    "assetHash": "^sha256:[a-f0-9]{64}$",
    "assetRole": "^[a-z0-9-]{1,32}$",
    "mime": "^[a-z0-9][a-z0-9.+-]*/[a-z0-9][a-z0-9.+-]*$",
    "tag": "^[a-z0-9-]{1,32}$"
  },
  "limits": {
    "maxTags": 12,
    "maxAssets": 128,
    "maxPackageBytes": 2097152,
    "maxEntryLength": 160,
    "maxAssetPathLength": 240
  },
  "manifestFields": [
    "schemaVersion",
    "runtime",
    "entry",
    "title",
    "description",
    "tags",
    "permissions",
    "assets"
  ],
  "assetFields": [
    "path",
    "mime",
    "size",
    "sha256",
    "role"
  ]
}
